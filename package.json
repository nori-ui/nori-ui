{
  "name": "unbogify-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling",
    "e2e/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "yarn workspaces foreach -A -pt run typecheck",
    "lint": "biome check . && yarn eslint:rn",
    "eslint:rn": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "yarn workspaces foreach -A -pt run test",
    "size": "yarn workspace unbogify-ui exec size-limit",
    "build:tokens": "yarn workspace @unbogify/tokens build"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9",
    "eslint-plugin-react-native": "^5",
    "globals": "^15",
    "jest": "^29",
    "lefthook": "^2.1.6",
    "size-limit": "^12.1.0",
    "ts-jest": "^29",
    "typescript": "^5.6.0"
  }
}
