{
  "name": "nori-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling",
    "e2e/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "yarn workspaces foreach -A -pt run typecheck",
    "lint": "biome check . && yarn eslint:rn",
    "eslint:rn": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "yarn workspaces foreach -A -pt run test",
    "size": "yarn workspace @nori-ui/core exec size-limit",
    "build:tokens": "yarn workspace @nori-ui/tokens build",
    "build:ui": "yarn workspace @nori-ui/core build",
    "dev:web": "yarn workspace playground-web dev",
    "dev:native": "yarn workspace playground-native start",
    "dev:storybook": "yarn workspace playground-web storybook",
    "build:storybook": "yarn workspace playground-web build:storybook",
    "dev:docs": "yarn workspace @nori-ui/docs dev",
    "build:docs": "yarn workspace @nori-ui/docs build",
    "test:mcp-eval": "yarn workspace @nori-ui/e2e-web test tests/mcp-eval.spec.ts",
    "test:e2e:web": "yarn workspace @nori-ui/e2e-web test",
    "e2e:browsers": "yarn workspace @nori-ui/e2e-web install:browsers"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.59.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9",
    "eslint-plugin-react-native": "^5",
    "globals": "^15",
    "jest": "^29",
    "lefthook": "^2.1.6",
    "semantic-release": "^23",
    "size-limit": "^12.1.0",
    "ts-jest": "^29",
    "typescript": "^5.6.0"
  },
  "resolutions": {
    "tailwindcss": "^3.4"
  }
}
