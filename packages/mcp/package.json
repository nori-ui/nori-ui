{
  "name": "@nori-ui/mcp",
  "version": "1.0.6",
  "description": "Local MCP server for nori-ui — bundles the docs corpus so AI agents can query components offline without hitting the docs site.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:nori-ui/nori-ui.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nori-ui-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node ../../apps/docs/scripts/generate-mcp-data.mjs && tsup",
    "typecheck": "node ../../apps/docs/scripts/generate-mcp-data.mjs && tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3.23"
  }
}
