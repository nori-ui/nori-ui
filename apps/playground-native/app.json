{
  "expo": {
    "name": "nori-ui-playground",
    "slug": "nori-ui-playground",
    "version": "0.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "scheme": "nori-ui",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nori-ui.playground",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon.png"
      }
    },
    "android": {
      "package": "com.noriui.playground",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#EFE7D2"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EFE7D2",
          "dark": {
            "image": "./assets/splash.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#1F2D24"
          }
        }
      ]
    ]
  }
}
