{
  "name": "@nori-ui/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "fumadocs-mdx && node scripts/generate-preview-sources.mjs && node scripts/generate-props.mjs && node scripts/generate-bundle-sizes.mjs && node scripts/generate-mcp-data.mjs",
    "dev": "yarn generate && next dev -p 3000",
    "build": "yarn generate && next build",
    "start": "next start -p 3000",
    "typecheck": "yarn generate && tsc --noEmit",
    "test": "yarn generate && jest --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "@nori-ui/core": "workspace:*",
    "@nori-ui/mcp": "workspace:*",
    "@nori-ui/tokens": "workspace:*",
    "fumadocs-core": "14.0.0",
    "fumadocs-mdx": "^11",
    "fumadocs-ui": "patch:fumadocs-ui@npm%3A14.0.0#~/.yarn/patches/fumadocs-ui-npm-14.0.0-557c7c2e7a.patch",
    "nativewind": "^4",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9",
    "react-native-css-interop": "^0.2.3",
    "react-native-web": "^0.21",
    "remark-gfm": "^4",
    "shiki": "^1.29",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "esbuild": "^0.25",
    "jest": "^29",
    "postcss": "^8",
    "react-docgen-typescript": "^2.2",
    "tailwindcss": "^3.4",
    "ts-jest": "^29",
    "typescript": "^5.6"
  }
}
