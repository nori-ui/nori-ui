# dependencies
node_modules/

# yarn berry — when using nodeLinker: node-modules, we still track a few yarn files
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# build output
dist/
build/
.next/
.source/
.turbo/
coverage/
*.tsbuildinfo

# generated registries — produced by predev/prebuild hooks
**/*.generated.ts
**/*.generated.json

# design tokens: build outputs ARE committed
!packages/tokens/build/

# caches
.cache/
.expo/
.parcel-cache/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.claude/

# storybook
storybook-static/

# playwright
e2e/web/playwright-report/
e2e/web/test-results/
.playwright-mcp/

# transient QA screenshots from interactive sessions
qa-*.png
findings.md
snapshot-*.md

# expo prebuild outputs — regenerated per build, not committed
apps/*/ios/
apps/*/android/

# project-local MCP config — per-developer
.mcp.json
# …except the plugin package's shipped .mcp.json (declared in its `files` field).
!packages/plugin/.mcp.json

# git worktrees (per-developer; never committed)
.worktrees/
# Added by code-review-graph
.code-review-graph/
