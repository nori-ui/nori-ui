# dependencies
node_modules/

# yarn berry — when using nodeLinker: node-modules, we still track a few yarn files
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# build output
dist/
build/
.next/
.source/
.turbo/
coverage/
*.tsbuildinfo

# generated registries — produced by predev/prebuild hooks
**/*.generated.ts

# design tokens: build outputs ARE committed
!packages/tokens/build/

# caches
.cache/
.expo/
.parcel-cache/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.claude/

# storybook
storybook-static/

# playwright
e2e/web/playwright-report/
e2e/web/test-results/
.playwright-mcp/

# transient QA screenshots from interactive sessions
qa-*.png
findings.md
